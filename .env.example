# Copy to .env and adjust per environment.

# PostgreSQL connection. Local dev uses the bundled docker-compose Postgres (host port 5433).
DATABASE_URL="postgresql://becatech:becatech@localhost:5433/beca_tech_dashboard?schema=public"

# Direct (non-pooled) connection used by Prisma Migrate. Locally identical to DATABASE_URL.
# On Vercel + Neon/Vercel Postgres: set DATABASE_URL to the POOLED url and DIRECT_URL to the DIRECT url.
DIRECT_URL="postgresql://becatech:becatech@localhost:5433/beca_tech_dashboard?schema=public"

# Mock auth for the MVP: which seeded demo user the app acts as (see prisma/seed.ts demo users).
# Options include: executive@becatech.test, program.manager@becatech.test, mentor1@becatech.test,
# analyst@becatech.test, finance@becatech.test, selection@becatech.test
DEMO_USER_EMAIL="program.manager@becatech.test"

# JotForm integration (placeholder — the MVP does not call the live API).
JOTFORM_API_KEY=""
JOTFORM_WEBHOOK_SECRET=""

# Separate database for integration tests (npm run test:integration). Same Docker Postgres,
# different database name. Created/migrated by the vitest global setup.
TEST_DATABASE_URL="postgresql://becatech:becatech@localhost:5433/beca_tech_test?schema=public"
